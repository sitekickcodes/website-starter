# ============================================
# Sitekick Payload Starter - Environment Variables
# ============================================
#
# Pull env vars from Vercel:
#   bun run env:pull   # runs `vercel env pull .env.local`
#
# Or copy this file and fill in the values by hand:
#   cp .env.example .env.local
# ============================================

# Payload CMS
PAYLOAD_SECRET=
POSTGRES_URL=
BLOB_READ_WRITE_TOKEN=

# Public site URL (used for metadata, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email — password resets, form notifications)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FORM_NOTIFICATION_EMAIL=

# Anthropic (AI-generated alt text for media uploads)
ANTHROPIC_API_KEY=

# ============================================
# Sitekick Payload Starter — Environment Variables
# ============================================
#
# Pull from Vercel:  bun run env:pull   (runs `vercel env pull .env.local`)
# Or by hand:        cp .env.example .env.local
# ============================================

# ── Payload / Database / Storage (required) ──
PAYLOAD_SECRET=
POSTGRES_URL=
BLOB_READ_WRITE_TOKEN=

# ── Public site ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Sitekick Starter

# ── Email (Resend) — optional; powers Payload auth/transactional email ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── AI alt text (Anthropic) — optional; auto-generates media alt text ──
ANTHROPIC_API_KEY=

# ── Analytics ──
# Google Analytics, Google Tag Manager, Meta Pixel, and PostHog IDs are managed
# in Payload Admin → Site Settings → Analytics. Vercel Analytics + Speed
# Insights require no project env var.

# ── Cron auth (Bearer token for /api/cron/* maintenance endpoints) ──
CRON_SECRET=
